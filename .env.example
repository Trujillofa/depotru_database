# Business Analyzer Configuration
# =================================
# Copy this file to .env and fill in your values
# DO NOT commit .env to version control!

# Option 1: Use Navicat NCX file for database credentials
NCX_FILE_PATH=/path/to/connections.ncx

# Option 2: Direct database connection (overrides NCX file if provided)
# DB_SERVER=your-server-host
# DB_PORT=1433
# DB_USER=your-username
# DB_PASSWORD=your-password
# DB_NAME=SmartBusiness
# DB_NAME_J3SYSTEM=J3System

# Connection pooling (on by default outside pytest; set 0 to disable)
# DB_POOL_ENABLED=1
# DB_POOL_SIZE=10
# DB_POOL_TIMEOUT=300

# Query timeouts (seconds) — raise DB_TIMEOUT for heavy aggregations on banco_datos
# DB_LOGIN_TIMEOUT=30
# DB_TIMEOUT=180
# DB_QUERY_RETRIES=2

# Output Configuration
OUTPUT_DIR=~/business_reports

# Report Settings
REPORT_DPI=300

# Analysis Defaults
DEFAULT_LIMIT=1000

# Logging
LOG_LEVEL=INFO

# =================================
# Vanna AI Configuration (Optional)
# =================================
# Choose ONE of the following AI providers for natural language SQL queries

# Option 1: OpenAI (Recommended - Best results)
# OPENAI_API_KEY=sk-your-openai-api-key-here

# Option 2: Grok (xAI)
# GROK_API_KEY=xai-your-grok-api-key-here

# Option 3: Anthropic Claude
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here

# Option 4: Ollama (Local, Free)
# No API key needed - just install Ollama locally

# Vanna API Key (Optional - for hosted vector DB with OpenAI)
# VANNA_API_KEY=your-vanna-api-key

# =================================
# Production Deployment (Optional)
# =================================
# Use production-grade Waitress server (handles 10-50 concurrent users)
# Default: false (uses Flask development server)
# PRODUCTION_MODE=true
# WAITRESS_THREADS=8

# Scheduled jobs — see deploy/depotru-schedule.cron.example
# Retrain Vanna after training.py changes:
#   PYTHONPATH=src python scripts/utils/retrain_vanna.py --reset

# Affinity pipeline (optional mart for faster co-occurrence reads)
# Apply data/sql/affinity_indexes_and_mart.sql first, then refresh nightly:
#   PYTHONPATH=src python scripts/analysis/refresh_affinity_mart.py
# AFFINITY_USE_MART=1
# AFFINITY_MART_TABLE=affinity_co_occurrence

# =================================
# REST API (Optional)
# =================================
# python src/api.py  →  http://localhost:8000
# When set, protected endpoints require header: X-API-Key: <value>
# API_KEY=your-secret-api-key

# =================================
# Query Cache (Optional)
# =================================
# CACHE_TTL_SECONDS=300
# CACHE_BACKEND=memory
# CACHE_BACKEND=redis
# REDIS_URL=redis://localhost:6379/0
