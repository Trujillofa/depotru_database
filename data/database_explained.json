							"category": "PVC pipes"
						},
						{
							"name": "EUROCERAMICA",
							"revenue": 9570179992,
							"category": "Ceramic tiles"
						}
					]
				},
				"marca": {
					"type": "NVARCHAR(100)",
					"description": "Tax category or product line (NOT the brand!)",
					"example": "PRODUCTOS GRAVADOS AL 5%",
					"warning": "This is NOT the product brand - use 'proveedor' for brand",
					"common_values": [
						"PRODUCTOS GRAVADOS AL 5%",
						"MATERIALES PARA CONSTRUCCION Y FONTANERIA",
						"PRODUCTOS GRAVADOS AL 19%"
					]
				},
				"categoria": {
					"type": "NVARCHAR(100)",
					"description": "Product category",
					"example": "ART Y HERRAMIENTAS AGRICOLAS",
					"top_categories": [
						{
							"name": "CEMENTO GRIS",
							"revenue": 45164889131,
							"transactions": 39136
						},
						{ "name": "HIERRO", "revenue": 44674602396, "transactions": 43538 },
						{ "name": "ZINC", "revenue": 38159975028, "transactions": 32656 },
						{
							"name": "PRODUCTOS SIKA",
							"revenue": 27443132851,
							"transactions": 107472
						},
						{
							"name": "PERFIERIA",
							"revenue": 22679673932,
							"transactions": 39509
						}
					]
				},
				"subcategoria": {
					"type": "NVARCHAR(100)",
					"description": "Product subcategory (often same as category)",
					"example": "BUJES"
				}
			},

			"location_fields": {
				"departamento": {
					"type": "NVARCHAR(100)",
					"description": "Colombian department (state)",
					"example": "HUILA"
				},
				"ciudad": {
					"type": "NVARCHAR(100)",
					"description": "City/Municipality",
					"example": "NEIVA"
				}
			},

			"financial_fields": {
				"_note": "All financial values in Colombian Pesos (COP)",
				"_format": "Use Colombian format: $1.234.567,89 (dots thousands, comma decimals)",

				"Cantidad": {
					"type": "DECIMAL(18,2)",
					"description": "Quantity sold (units/kg/meters/etc)",
					"example": 3.0
				},
				"VentaSinIva": {
					"type": "DECIMAL(18,4)",
					"description": "Line item price without tax",
					"example": "5929.0000"
				},
				"VentaMasIva": {
					"type": "DECIMAL(18,4)",
					"description": "Line item price with tax",
					"example": "6225.4500"
				},
				"TotalSinIva": {
					"type": "DECIMAL(18,2)",
					"description": "Total line revenue without tax (VentaSinIva * Cantidad - discount)",
					"example": 17787.0,
					"formula": "SUM(TotalSinIva) = Net Revenue"
				},
				"TotalMasIva": {
					"type": "DECIMAL(18,2)",
					"description": "Total line revenue with tax (VentaMasIva * Cantidad - discount)",
					"example": 18676.35,
					"formula": "SUM(TotalMasIva) = Gross Revenue (Facturación)"
				},
				"ValorCosto": {
					"type": "DECIMAL(18,2)",
					"description": "Total cost of goods sold",
					"example": 15467.28,
					"formula": "Profit = TotalSinIva - ValorCosto"
				},
				"Iva": {
					"type": "DECIMAL(5,2)",
					"description": "VAT/Tax percentage",
					"example": 5.0,
					"common_values": [0.0, 5.0, 19.0]
				},
				"PorDescuento": {
					"type": "DECIMAL(5,2)",
					"description": "Discount percentage",
					"example": 0.0
				},
				"ValorDescuento": {
					"type": "DECIMAL(18,12)",
					"description": "Discount value",
					"example": "0e-12"
				},
				"LineasPorcentaje": {
					"type": "DECIMAL(5,2)",
					"description": "Line margin/discount percentage",
					"example": 5.0
				}
			},

			"date_fields": {
				"Fecha": {
					"type": "DATE",
					"description": "Transaction date (YYYY-MM-DD)",
					"example": "2025-01-07",
					"sql_functions": {
						"YEAR": "YEAR(Fecha) - Get year (e.g., 2025)",
						"MONTH": "MONTH(Fecha) - Get month 1-12",
						"DAY": "DAY(Fecha) - Get day of month",
						"DATEPART": "DATEPART(QUARTER, Fecha) - Get quarter 1-4",
						"DATENAME": "DATENAME(MONTH, Fecha) - Get month name (e.g., 'Enero')"
					}
				},
				"ano": {
					"type": "INTEGER",
					"description": "Year (redundant with YEAR(Fecha))",
					"example": 2025
				},
				"mes": {
					"type": "INTEGER",
					"description": "Month 1-12 (redundant with MONTH(Fecha))",
					"example": 1
				},
				"dia": {
					"type": "INTEGER",
					"description": "Day of month 1-31 (redundant with DAY(Fecha))",
					"example": 7
				},
				"periodo": {
					"type": "INTEGER",
					"description": "Period code: YYYY * 10 + Month (e.g., 20251 = Jan 2025)",
					"example": 20251,
					"formula": "periodo = ano * 10 + mes"
				}
			},

			"credit_fields": {
				"DiasCredito": {
					"type": "INTEGER",
					"description": "Credit days for this transaction",
					"example": 0,
					"values": {
						"0": "Cash sale (contado)",
						">0": "Credit sale (credito) - Use VendedorAsignado for vendor"
					}
				}
			}
		}
	},

	"calculated_metrics": {
		"revenue_gross": {
			"description": "Gross revenue with tax (Facturación)",
			"sql": "SUM(TotalMasIva)",
			"alias": "Facturacion_Total"
		},
		"revenue_net": {
			"description": "Net revenue without tax (Ventas Netas)",
			"sql": "SUM(TotalSinIva)",
			"alias": "Ventas_Netas"
		},
		"cost_total": {
			"description": "Total cost of goods sold",
			"sql": "SUM(ValorCosto)",
			"alias": "Costo_Total"
		},
		"profit": {
			"description": "Gross profit (Ganancia)",
			"sql": "SUM(TotalSinIva - ValorCosto)",
			"alias": "Ganancia_Total"
		},
		"profit_margin_pct": {
			"description": "Profit margin percentage (Margen)",
			"sql": "(TotalSinIva - ValorCosto) * 100.0 / NULLIF(TotalSinIva, 0)",
			"alias": "Margen_Porcentaje",
			"note": "Use NULLIF to avoid division by zero"
		},
		"tax_iva": {
			"description": "VAT/Tax amount (IVA)",
			"sql": "SUM(TotalMasIva - TotalSinIva)",
			"alias": "IVA_Total"
		},
		"quantity_total": {
			"description": "Total quantity sold",
			"sql": "SUM(Cantidad)",
			"alias": "Cantidad_Total"
		},
		"transaction_count": {
			"description": "Number of transactions",
			"sql": "COUNT(*)",
			"alias": "Numero_Transacciones"
		},
		"average_ticket": {
			"description": "Average transaction value",
			"sql": "SUM(TotalMasIva) / COUNT(*)",
			"alias": "Ticket_Promedio"
		}
	},

	"common_query_patterns": {
		"top_n": {
			"description": "Get top N results",
			"sql": "SELECT TOP N ... ORDER BY metric DESC"
		},
		"time_filter_year": {
			"description": "Filter by year",
			"sql": "YEAR(Fecha) = 2025"
		},
		"time_filter_current_year": {
			"description": "Current year",
			"sql": "YEAR(Fecha) = YEAR(GETDATE())"
		},
		"time_filter_last_30_days": {
			"description": "Last 30 days",
			"sql": "Fecha >= DATEADD(DAY, -30, GETDATE())"
		},
		"time_filter_last_month": {
			"description": "Last month",
			"sql": "Fecha >= DATEADD(MONTH, -1, GETDATE())"
		},
		"brand_search": {
			"description": "Search for brand across all brand fields",
			"sql": "(proveedor = 'BRAND' OR categoria = 'BRAND' OR subcategoria = 'BRAND' OR marca = 'BRAND' OR ArticulosNombre LIKE '%BRAND%')"
		},
		"vendor_search": {
			"description": "Search for vendor across all vendor fields",
			"sql": "(VendedorFactura LIKE '%NAME%' OR vendedor_codigo LIKE '%CODE%' OR VendedorAsignado LIKE '%NAME%')"
		}
	},

	"sample_queries": {
		"top_products_by_revenue": {
			"description": "Top 10 products by revenue this year",
			"natural_language": "Top 10 productos más vendidos por facturación este año",
			"sql": "SELECT TOP 10 ArticulosNombre, SUM(TotalMasIva) AS Ventas FROM banco_datos WHERE DocumentosCodigo NOT IN ('XY', 'AS', 'TS', 'YX', 'ISC') AND YEAR(Fecha) = YEAR(GETDATE()) GROUP BY ArticulosNombre ORDER BY Ventas DESC"
		},
		"monthly_sales": {
			"description": "Monthly sales current year",
			"natural_language": "Ventas mensuales del año actual",
			"sql": "SELECT MONTH(Fecha) AS Mes, DATENAME(MONTH, Fecha) AS Nombre_Mes, SUM(TotalMasIva) AS Ventas FROM banco_datos WHERE DocumentosCodigo NOT IN ('XY', 'AS', 'TS', 'YX', 'ISC') AND YEAR(Fecha) = YEAR(GETDATE()) GROUP BY MONTH(Fecha), DATENAME(MONTH, Fecha) ORDER BY Mes"
		},
		"sika_products_2026": {
			"description": "SIKA products sales 2026",
			"natural_language": "ventas del 2026 en la marca sika",
			"sql": "SELECT ArticulosNombre, SUM(TotalMasIva) AS Ventas, SUM(Cantidad) AS Unidades FROM banco_datos WHERE DocumentosCodigo NOT IN ('XY', 'AS', 'TS', 'YX', 'ISC') AND YEAR(Fecha) = 2026 AND (proveedor = 'SIKA' OR categoria = 'SIKA' OR subcategoria = 'SIKA' OR ArticulosNombre LIKE '%SIKA%') GROUP BY ArticulosNombre ORDER BY Ventas DESC"
		}
	},

