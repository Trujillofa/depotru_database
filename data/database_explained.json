	},

	"critical_rules": {
		"excluded_document_codes": {
			"codes": ["XY", "AS", "TS", "YX", "ISC"],
			"description": "ALWAYS exclude these document codes - they represent test transactions, cancellations, or internal adjustments",
			"sql_clause": "WHERE DocumentosCodigo NOT IN ('XY', 'AS', 'TS', 'YX', 'ISC')",
			"importance": "CRITICAL - Every query must include this filter"
		},
		"negative_values": {
			"description": "Negative values in financial fields represent returns/cancellations",
			"handling": "Include by default unless analyzing returns specifically"
		},
		"date_format": {
			"description": "YYYY-MM-DD format (ISO 8601)",
			"examples": ["2025-01-07", "2026-04-15"]
		}
	},

	"schema": {
		"table_name": "banco_datos",
		"description": "Main sales transaction table for ferretería (hardware store) operations",
		"record_type": "Sales transactions including invoices, credit notes, and adjustments",

		"fields": {
			"transaction_identifiers": {
				"VentaID": {
					"type": "INTEGER PRIMARY KEY",
					"description": "Unique transaction line ID",
					"example": 353533,
					"usage": "Use for deduplication or specific record lookup"
				},
				"DocumentosCodigo": {
					"type": "NVARCHAR(10)",
					"description": "Document type code - CRITICAL for filtering",
					"values": {
						"FED": {
							"name": "FACTURA ELECTRONICA DE VENTA",
							"description": "Main store (Almacen) - Standard electronic invoice",
							"return_code": "DVE"
						},
						"FEF": {
							"name": "FACTURA ELECTRONICA FLORENCIA",
							"description": "Florencia branch store"
						},
						"FET": {
							"name": "FACTURA ELECTRONICA CALLE 5",
							"description": "Calle 5 / Distribuciones store"
						},
						"DVE": {
							"name": "DEVOLUCION DE VENTA ELECTRONICA",
							"description": "Return/credit note for FED"
						},
						"XY": {
							"name": "TEST/ADJUSTMENT",
							"description": "Test documents - ALWAYS EXCLUDE",
							"exclude": true
						},
						"AS": {
							"name": "ADJUSTMENT",
							"description": "System adjustments - ALWAYS EXCLUDE",
							"exclude": true
						},
						"TS": {
							"name": "TEST SALES",
							"description": "Test sales - ALWAYS EXCLUDE",
							"exclude": true
						}
					},
					"business_rule": "ALWAYS filter: WHERE DocumentosCodigo NOT IN ('XY', 'AS', 'TS', 'YX', 'ISC')"
				},
				"DocumentosNombre": {
					"type": "NVARCHAR(100)",
					"description": "Full document type name",
					"example": "FACTURA ELECTRONICA DE VENTA"
				},
				"NumeroDocumento": {
					"type": "INTEGER",
					"description": "Invoice/Receipt number",
					"example": 300320,
					"usage": "Unique per DocumentosCodigo. FED-300320 is different from FEF-300320"
				}
			},

			"vendor_seller_fields": {
				"_note": "Vendedor = Seller/Vendor (NOT customer!). These are employees who made the sale",
				"VendedorID": {
					"type": "INTEGER",
					"description": "Vendor ID in system",
					"example": 46
				},
				"VendedorFactura": {
					"type": "NVARCHAR(200)",
					"description": "Vendor name as shown on receipt",
					"example": "AMELIA SOTELO NARVAEZ",
					"top_vendors": [
						"CARLOS EFREY PASCUAS",
						"YULI ALEJANDRA HIGUERA",
						"ANDRES FELIPE VARGAS JOVEL",
						"AMELIA SOTELO NARVAEZ",
						"OSCAR IVAN POLANIA GARCIA"
					]
				},
				"vendedor_codigo": {
					"type": "NVARCHAR(50)",
					"description": "Vendor code/number",
					"example": "106",
					"note": "May be NULL for some vendors"
				},
				"VendedorAsignado": {
					"type": "NVARCHAR(200)",
					"description": "Vendor assigned for credit sales",
					"example": "106-DIANA PATRICIA CULMA",
					"note": "Only populated for credit transactions (DiasCredito > 0)"
				}
			},

			"customer_fields": {
				"_note": "Terceros = Third parties = Customers",
				"TercerosID": {
					"type": "INTEGER",
					"description": "Customer ID in system",
					"example": 4605
				},
				"TercerosIdentificacion": {
					"type": "NVARCHAR(50)",
					"description": "Customer NIT/ID number",
					"example": "83167817"
				},
				"TercerosNombres": {
					"type": "NVARCHAR(200)",
					"description": "Customer full name",
					"example": "MANUEL ROBERTO LONDOÑO CHARRY",
					"top_customers": [
						"FERRETERIA MAGRETH S A S",
						"ONG FUNDACION GESTION SOCIAL D",
						"FREDI TRUJILLO CULMA",
						"FERRETERIA LA GRAN REBAJA DE C",
						"GIL ANTONIO VARGAS MERCHAN"
					]
				}
			},

			"product_fields": {
				"ArticulosID": {
					"type": "INTEGER",
					"description": "Product ID in system",
					"example": 4152
				},
				"ArticulosCodigo": {
					"type": "NVARCHAR(50)",
					"description": "Product SKU/Code",
					"example": "0100050058"
				},
				"ArticulosNombre": {
					"type": "NVARCHAR(200)",
					"description": "Product full name",
					"example": "CUCHILLA GUAD/BELL ROJA C16 1\" RF:351625",
					"top_products": [
						"AMARRES PARA TEJA",
						"CEMENTO GRIS USO GENERAL CEMEX 50KG",
						"ALAMBRE NEGRO RECOCIDO X KILO CONTINUO",
						"ROLLO CORRUGADO X KG 1/4\" SR NTC 2289",
						"CODO PRESION 90 1/2 T/PESADO"
					]
				},
				"ArticulosReferencia": {
					"type": "NVARCHAR(100)",
					"description": "Product reference code (often empty)",
					"example": "351625"
				},
				"AlmacenCodigo": {
					"type": "NVARCHAR(10)",
					"description": "Warehouse/Store code",
					"example": "ALM",
					"values": {
						"ALM": "Almacen principal (Main warehouse)"
					}
				}
			},

			"classification_fields": {
				"_note": "Hierarchy: proveedor (brand) → categoria (category) → subcategoria (subcategory)",
				"proveedor": {
					"type": "NVARCHAR(100)",
					"description": "Product provider/manufacturer brand",
					"example": "BELLOTA",
					"top_brands": [
						{ "name": "CEMEX", "revenue": 47156611463, "category": "Cement" },
						{
							"name": "ACESCO",
							"revenue": 42795789520,
							"category": "Steel/Iron"
						},
						{
							"name": "SIKA",
