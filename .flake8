[flake8]
max-line-length = 88
extend-ignore = E203,W503
exclude =
    .git,
    __pycache__,
    .pytest_cache,
    .mypy_cache,
    .ruff_cache,
    src/business_analyzer_combined.py,
    src/vanna_chat.py,
    src/config.py,
    tests/test_behavior_baseline_smoke.py,
    tests/test_business_metrics.py,
    tests/test_metabase_connection.py,
    examples/improvements_p0.py,
    examples/pandas_approach.py,
    examples/streamlit_dashboard.py
